{
  "schemaVersion": 1,
  "id": "mat",
  "version": "${version}",
  "name": "MAT",
  "description": "MC Automation Tools — scriptable Baritone-based automation framework.",
  "authors": [
    "myflycat"
  ],
  "contact": {},
  "license": "LGPL-3.0",
  "environment": "client",
  "entrypoints": {
    "fabric-datagen": [
      "cn.myflycat.mat.client.MatDataGenerator"
    ],
    "client": [
      "cn.myflycat.mat.client.MatClient"
    ],
    "main": [
      "cn.myflycat.mat.Mat"
    ]
  },
  "mixins": [
    "mat.mixins.json",
    {
      "config": "mat.client.mixins.json",
      "environment": "client"
    }
  ],
  "depends": {
    "fabricloader": ">=${loader_version}",
    "fabric-api": "*",
    "minecraft": "${minecraft_version}"
  }
}
